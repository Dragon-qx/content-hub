{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "composite": true,
    "paths": {
      "@content-hub/platform-sdk": ["../platform-sdk/src"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../platform-sdk" }]
}
