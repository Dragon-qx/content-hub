# Dockerfile.web — ContentHub Web (Next.js standalone output)
FROM node:22-bookworm-slim AS base
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9 --activate

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/platform-sdk/package.json ./packages/platform-sdk/
RUN pnpm install --frozen-lockfile

FROM base AS builder
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared-types/node_modules ./packages/shared-types/node_modules
COPY --from=deps /app/packages/platform-sdk/node_modules ./packages/platform-sdk/node_modules
COPY . .
# Build workspace deps first, then web (Next.js standalone)
RUN pnpm --filter=@content-hub/shared-types build
RUN pnpm --filter=@content-hub/platform-sdk build
RUN cd /app/apps/web && pnpm run build

FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Next.js standalone output carries its own node_modules. The standalone tree is
# rooted at `apps/web/` (so server.js lives at that nested path), therefore we
# copy it to /app and enter that subdir both for `server.js` and for `public/`.
COPY --from=builder /app/apps/web/.next/standalone ./
# .next/static lives outside the standalone tree, so it must be copied in
# separately and placed next to the standalone's server.js (under apps/web).
COPY --from=builder /app/apps/web/.next/static ./.next/static
COPY --from=builder /app/apps/web/public ./public
WORKDIR /app/apps/web

EXPOSE 3001
CMD ["node", "server.js"]
