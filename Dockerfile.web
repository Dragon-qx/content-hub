# Dockerfile.web — ContentHub Web (Next.js standalone output)
FROM node:22-bookworm-slim AS base
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9 --activate

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY packages/platform-sdk/package.json ./packages/platform-sdk/
RUN pnpm install --frozen-lockfile

FROM base AS builder
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared-types/node_modules ./packages/shared-types/node_modules
COPY --from=deps /app/packages/platform-sdk/node_modules ./packages/platform-sdk/node_modules
COPY . .
# Build workspace deps first, then web (Next.js standalone)
RUN pnpm --filter=@content-hub/shared-types build
RUN pnpm --filter=@content-hub/platform-sdk build
RUN cd /app/apps/web && pnpm run build

FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
# Next.js standalone builder emits `apps/web/.next/standalone/` preserving the
# workspace path, so the standalone tree's *root* is `apps/web/` and looks like
#   standalone/apps/web/{server.js,package.json,public,node_modules}
#                                     .next/{BUILD_ID,*.json,...}
# (Note: there is NO `static` folder here — `.next/static` lives *outside* the
# standalone tree and is copied in separately below.)
#
# Recreate the workspace layout under /app so the SDK/node_modules resolution
# that worked in the builder carries over unchanged. The only file we
# explicitly reference later is apps/web/server.js.
#
# The standalone tree's root is `apps/web/` (it preserves the workspace path),
# so we copy it to `./` — that places server.js at /app/apps/web/server.js.
COPY --from=builder /app/apps/web/.next/standalone ./
# .next/static is outside the standalone tree — place it next to server.js.
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
# static assets (manifest, icons, service worker)
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3001
CMD ["node", "apps/web/server.js"]
