node_modules
# Per-package installs are symlinks; the builder copies these freshly from
# the root `.pnpm` store (COPY --from=deps). They must not be clobbered by
# `COPY . .`, which would otherwise bring in local OS-absolute symlinks.
packages/*/node_modules
apps/*/node_modules
npm-debug.log*
.git
.github
.gitignore
.env
.env.*
!.env.example
*.md
!README.md
dist
.next
coverage
.nyc_output
.cache
tmp
temp
*.log
.DS_Store
.vscode
.idea
*.tsbuildinfo
