// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  avatarUrl     String?
  role          UserRole  @default(OWNER)
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  auditLogs     AuditLog[]
}

model Team {
  id                String    @id @default(cuid())
  name              String
  description       String?
  ownerId           String
  members           Member[]
  accounts          SocialAccount[]
  accountGroups     AccountGroup[]
  users             User[]
  sentimentKeywords SentimentKeyword[]
  templates         ContentTemplate[]
  wallet            Wallet?
  healthThreshold   HealthThreshold?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Member {
  id        String     @id @default(cuid())
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id])
  userId    String
  role      MemberRole @default(EDITOR)
  joinedAt  DateTime   @default(now())

  @@unique([teamId, userId])
}

model AccountGroup {
  id          String          @id @default(cuid())
  teamId      String
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String?         // Hex color for UI chip (e.g. "#3b82f6")
  accounts    SocialAccount[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([teamId])
}

model SocialAccount {
  id              String          @id @default(cuid())
  teamId          String
  team            Team            @relation(fields: [teamId], references: [id])
  groupId         String?
  group           AccountGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  platform        Platform
  accountId       String          // 平台唯一标识
  accountName     String
  accountHandle   String?
  credentials     Json            // 平台 OAuth/cookie 加密存储
  status          AccountStatus   @default(ACTIVE)
  followerCount   Int?
  followingCount  Int?
  postCount       Int?
  lastSyncedAt    DateTime?
  authFailCount   Int             @default(0)
  apiRateLimitPct Float?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  analytics       AnalyticsSnapshot[]
  publishJobs     PublishJob[]
  comments        EngagementComment[]
  messages        EngagementMessage[]
  anomalyAlerts   AnomalyAlert[]
  transfers       AccountTransfer[]
  receipts        PublishReceipt[]
  health          AccountHealth?

  @@unique([platform, accountId])
}

model Content {
  id            String         @id @default(cuid())
  teamId        String
  title         String
  body          String?        // Markdown
  contentType   ContentType
  status        ContentStatus  @default(DRAFT)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  createdBy     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  mediaAssets   MediaAsset[]
  platformPosts PlatformPost[]
  receipts      PublishReceipt[]
  tags          ContentTag[]
  workflow      Workflow[]
  versions      ContentVersion[]
  version       Int            @default(1)
}

model ContentVersion {
  id          String   @id @default(cuid())
  contentId   String
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  body        String?
  contentType ContentType
  changedBy   String
  changeNote  String?
  createdAt   DateTime @default(now())

  @@index([contentId])
}

// Reusable content templates scoped to a team. A template captures a body,
// content type and tags so editors can spin up new content from a proven
// starting point (PRD §3.3 内容模板, P1).
model ContentTemplate {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  contentType ContentType @default(TEXT)
  tags        String[] @default([])
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
}

model MediaAsset {
  id          String   @id @default(cuid())
  contentId   String?
  content     Content?  @relation(fields: [contentId], references: [id])
  type        MediaType
  url         String
  thumbnailUrl String?
  width       Int?
  height      Int?
  duration    Int?      // 视频时长（秒）
  fileSize    Int       // 字节
  mimeType    String    @default("application/octet-stream")
  uploadedBy  String?
  receipt     PublishReceipt?
  createdAt   DateTime  @default(now())
}

model PlatformPost {
  id              String        @id @default(cuid())
  contentId       String
  content         Content       @relation(fields: [contentId], references: [id])
  platform        Platform
  externalId      String?       // 平台侧内容 ID
  externalUrl     String?
  status          PublishStatus @default(PENDING)
  publishedAt     DateTime?
  retryCount      Int           @default(0)
  lastError       String?
  metrics         Json?         // 最新指标快照
  // Owning job, if this post was produced by a PublishJob.
  job             PublishJob?   @relation("JobPost", fields: [jobId], references: [id])
  jobId           String?       @unique
  receipt         PublishReceipt?
  createdAt       DateTime      @default(now())

  @@index([jobId])
}

model PublishJob {
  id            String        @id @default(cuid())
  contentId     String
  platform      Platform      @default(WECHAT_OFFICIAL)
  // The social account used to publish (resolved from content.teamId at schedule time).
  accountId     String?
  account       SocialAccount? @relation(fields: [accountId], references: [id])
  // Inverse of PlatformPost.job — the post produced by executing this job.
  post          PlatformPost?  @relation("JobPost")
  status        JobStatus     @default(QUEUED)
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?
  retryCount    Int           @default(0)
  createdAt     DateTime      @default(now())

  @@index([status, scheduledAt])
  @@index([accountId])
}

model AnalyticsSnapshot {
  id              String          @id @default(cuid())
  accountId       String
  account         SocialAccount   @relation(fields: [accountId], references: [id])
  snapshotDate    DateTime
  followerCount   Int?
  followingCount  Int?
  postCount       Int?
  impressions     Int?
  engagements     Int?
  likes           Int?
  comments        Int?
  shares          Int?
  views           Int?
  extra           Json?
  createdAt       DateTime        @default(now())

  @@unique([accountId, snapshotDate])
}

/// Record of an anomaly-detection alert broadcast to a team. The `signature`
/// field summarises which (type, metric) tuples fired, so consecutive polling
/// ticks only re-alert when the set of active anomalies *changes* — preventing
/// a persistent outage from spamming the team.
model AnomalyAlert {
  id         String        @id @default(cuid())
  accountId  String
  account    SocialAccount @relation(fields: [accountId], references: [id])
  teamId     String
  /// Pipe-joined list of `type:metric` that fired (sorted alphabetically).
  signature  String
  count      Int           @default(0)
  createdAt  DateTime      @default(now())

  @@index([accountId, createdAt])
  @@index([teamId, createdAt])
}

// Enums
enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum MemberRole {
  ADMIN
  EDITOR
  VIEWER
}

enum Platform {
  WECHAT_OFFICIAL
  WECHAT_VIDEO
  DOUYIN
  XIAOHONGSHU
  BILIBILI
  WEIBO
  TWITTER
  YOUTUBE
}

enum AccountStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum HealthStatus {
  OK
  WARNING
  CRITICAL
}

/// Computed health snapshot per social account. Recomputed on each scan;
/// the `alertSignature` enables the same turnstile-dedup as AnomalyAlert so
/// a persistent issue does not spam the team on every tick.
model AccountHealth {
  id              String       @id @default(cuid())
  accountId      String       @unique
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  teamId         String

  // Per-dimension status
  tokenStatus    HealthStatus @default(OK)
  tokenExpiresAt DateTime?
  apiRateStatus  HealthStatus @default(OK)
  apiRateLimitPct Float?
  syncStatus     HealthStatus @default(OK)
  lastSyncedAt   DateTime?
  authStatus     HealthStatus @default(OK)
  authFailCount  Int          @default(0)
  publishStatus  HealthStatus @default(OK)
  publishFailCount Int        @default(0)

  // Overall roll-up
  overallStatus  HealthStatus @default(OK)

  // Alert dedup
  lastAlertAt    DateTime?
  lastAlertSignature String?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([teamId])
  @@index([overallStatus])
  @@index([teamId, overallStatus])
}

/// Team-level thresholds that drive the health scan. One row per team.
model HealthThreshold {
  id                   String   @id @default(cuid())
  teamId               String   @unique
  team                 Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tokenExpireDays      Int      @default(7)
  apiRateLimitPct      Float    @default(80)
  syncStaleDays        Int      @default(7)
  authFailThreshold    Int      @default(3)
  publishFailThreshold Int      @default(3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Lifecycle of an account handover between teams. One active (PENDING)
/// transfer per account is enforced by the service layer.
enum TransferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model AccountTransfer {
  id            String         @id @default(cuid())
  accountId     String
  account       SocialAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fromTeamId    String
  toTeamId      String
  initiatorId   String         // user who requested the handover
  note          String?
  status        TransferStatus @default(PENDING)
  decidedById   String?        // user at the destination team who accepted/rejected
  decidedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([accountId, status])
  @@index([toTeamId, status])
}

/// Credits wallet for a team. One row per team, keyed by (teamId).
/// `balance` is stored in integer minor units (cents). Always >= 0; the
/// conditional update in WalletService prevents overdraft.
model Wallet {
  id          String   @id @default(cuid())
  teamId      String   @unique
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  balance     Int      @default(0)
  holdBalance Int      @default(0)
  currency    String   @default("CREDIT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  transactions WalletTransaction[]
}

/// Append-only ledger. Amounts are signed integer minor units:
///   positive = credit (top-up / refund), negative = debit (usage).
/// `balance_after` captures the post-transaction balance for auditability.
enum TransactionType {
  TOPUP
  REFUND
  PUBLISH
  SCHEDULE
  SYNC
  MEDIA_PROCESS
  AI_ASSIST
}

model WalletTransaction {
  id            String          @id @default(cuid())
  walletId      String
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Int             // signed minor units
  balanceAfter  Int
  refId         String?         // e.g. contentId / jobId
  note          String?
  createdAt     DateTime        @default(now())

  @@index([walletId, createdAt])
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
  CAROUSEL
  THREAD
  ARTICLE
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum PublishStatus {
  PENDING
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // info / success / warning / error
  channel   String   @default("in_app") // in_app / email / webhook
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model ContentTag {
  id        String   @id @default(cuid())
  contentId String
  content   Content  @relation(fields: [contentId], references: [id])
  name      String
  createdAt DateTime  @default(now())
}

model Workflow {
  id               String   @id @default(cuid())
  contentId        String?
  content          Content?  @relation(fields: [contentId], references: [id])
  approverId       String
  status           String   @default("PENDING") // PENDING / APPROVED / REJECTED
  comment          String?
  timeoutHours     Int?      @default(48) // auto-action time window (hours); null = no timeout
  timeoutAction    String?  // APPROVE | REJECT | ESCALATE
  escalateTo       String?  // userId to escalate to when action = ESCALATE
  firstReminderAt DateTime?
  createdAt        DateTime @default(now())

  @@index([status, createdAt])
}

// ── Engagement Hub ─────────────────────────────────────────────────

// An aggregated social comment ingested for a social account. Keyed by
// (accountId, externalId) so re-ingesting the same platform comment is
// idempotent. Sentiment is derived locally at ingest time.
model EngagementComment {
  id           String        @id @default(cuid())
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId   String        // platform-side comment id
  platform     Platform
  postExternalId String?     // originating post, if the adapter supplies it
  authorName   String
  authorId     String?
  content      String
  likeCount    Int           @default(0)
  parentId     String?       // thread parent, if supplied
  sentiment    Sentiment     @default(NEUTRAL)
  sentimentScore Float       @default(0) // -1 … +1 heuristic
  replied      Boolean       @default(false)
  replyContent String?
  repliedAt    DateTime?
  // True once an alert notification has been broadcast for this comment, so the
  // same angry comment never pings the team twice.
  alerted      Boolean       @default(false)
  commentDate  DateTime      // the platform's creation time
  fetchedAt    DateTime      @default(now())
  metadata     Json?

  @@unique([accountId, externalId])
  @@index([accountId, sentiment])
  @@index([accountId, replied])
}

/// Server-side, tamper-evident record that a given content piece was handed
/// off to a platform adapter for publication at a specific instant. Holds the
/// external URL + a retained card image (PNG) generated from the publish
/// metadata. Tied to its PlatformPost (one receipt per post). `assetId`
/// optionally references a retained screenshot/media asset; the receipt is
/// still available as a card-image fallback when no real screenshot is held.
model PublishReceipt {
  id             String        @id @default(cuid())
  contentId      String
  content        Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platformPostId String?       @unique
  platformPost   PlatformPost? @relation(fields: [platformPostId], references: [id], onDelete: SetNull)
  accountId      String?
  account        SocialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  platform       Platform
  externalId     String?
  externalUrl    String?
  assetId        String?       @unique
  asset          MediaAsset?   @relation(fields: [assetId], references: [id])
  receiptHash    String        @unique
  metadata       Json?
  generatedAt    DateTime      @default(now())

  @@index([contentId])
  @@index([platformPostId])
}

/// A custom drag-and-drop report saved by a user (PRD §3.5).
model CustomReport {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  /// Selected field ids, in display order.
  fieldIds    String[]
  /// Optional filter config (JSON string for portability).
  filtersJson String?  @default("{}")
  /// Group-by field id, if any.
  groupBy     String?
  /// Sort field id and direction (`asc` | `desc`).
  sortBy      String?
  sortDir     String   @default("desc")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
}

// Sentiment label derived from content at ingest time.
enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// User-authored quick-reply templates for the engagement inbox.
model CommentTemplate {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// An aggregated private message ingested for a social account. Keyed by
// (accountId, externalId) so re-ingesting the same platform message is
// idempotent. `sentByMe` marks outgoing replies so the inbox can show history.
model EngagementMessage {
  id             String        @id @default(cuid())
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId     String        // platform-side message id
  platform       Platform
  conversationId String?       // thread the message belongs to, if supplied
  authorName     String
  authorId       String?
  content        String
  sentByMe       Boolean       @default(false)
  messageDate    DateTime      // the platform's creation time
  fetchedAt      DateTime      @default(now())
  metadata       Json?

  @@unique([accountId, externalId])
  @@index([accountId, conversationId])
  @@index([accountId, messageDate])
}

// Team-owned watch keywords for the sentiment alerting engine. When an
// ingested comment matches any keyword (or is strongly negative), the team is
// notified. Unique per team so the same keyword isn't added repeatedly.
model SentimentKeyword {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  keyword   String
  createdBy String
  createdAt DateTime @default(now())

  @@unique([teamId, keyword])
  @@index([teamId])
}
