# ─────────────────────────────────────────────────────────────────────────────
# ContentHub environment configuration
# Copy to `.env` (local) or inject via your orchestrator (production).
# Every value below has a safe dev default unless marked [REQUIRED].
# ─────────────────────────────────────────────────────────────────────────────

# ── Database [REQUIRED] ───────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://user:pass@localhost:5432/contenthub

# Local dev only — docker-compose uses the values baked into its service def.
# POSTGRES_USER=user
# POSTGRES_PASSWORD=pass
# POSTGRES_DB=contenthub

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development              # development | production | test
PORT=3000                         # API listen port
API_URL=http://localhost:3000     # Public API base URL
WEB_URL=http://localhost:3001     # Used for OAuth success redirects if FRONTEND_URL unset

# ── Notification delivery ────────────────────────────────────────────────
# SMTP (email notifications). If unset, email channel is silently skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false       # true for TLS (port 465), false for STARTTLS (port 587)
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ContentHub <no-reply@contenthub.dev>

# Webhook (team-level outbound). Used when channel=webhook and no per-notification
# webhookUrl is supplied. POSTed JSON: {notificationId,userId,type,title,body,link,timestamp}.
WEBHOOK_URL=

# ── Auth / JWT [REQUIRED in production] ───────────────────────────────────────
JWT_SECRET=change-me-in-production                # >= 32 chars [REQUIRED prod]
JWT_REFRESH_SECRET=change-me-too-in-production    # >= 32 chars [REQUIRED prod]
JWT_EXPIRES_IN=15m                # Access token lifetime (vercel/ms format)
JWT_REFRESH_EXPIRES_IN=7d         # Refresh token lifetime

# ── Credential encryption [REQUIRED in production] ──────────────────────────
# AES-256-GCM key used to encrypt social-account credentials at rest.
# If unset, falls back to JWT_SECRET (dev-only — never in production).
# CREDENTIAL_ENCRYPTION_KEY=

# ── OAuth ────────────────────────────────────────────────────────────────────
FRONTEND_URL=                     # SPA origin for post-bind OAuth redirect
OAUTH_SUCCESS_REDIRECT=           # Fallback redirect target (defaults to FRONTEND_URL -> WEB_URL -> localhost:3001)

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000           # Sliding-window size (ms)
RATE_LIMIT_MAX=100                # Max requests per window per user/IP

# ── Background worker (apps/api `node dist/worker`) ────────────────────────────
WORKER_POLL_INTERVAL_MS=10000     # Publish-job poll tick (ms)
WORKER_BATCH_SIZE=5               # Max jobs executed per tick
WORKER_ENGAGEMENT_SYNC_INTERVAL_MS=600000   # Comment inbox sync cadence (ms)
WORKER_ANOMALY_SCAN_INTERVAL_MS=21600000    # Anomaly detection cadence (~6h)

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=info                    # NestJS log verbosity

# ── Docs artifact ──────────────────────────────────────────────────────────────
# Set to 1 during build to emit dist/openapi.json (also via `pnpm openapi`).
WRITERSWAPI_DOC=0
